{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowLink",
  "version": "0.1.0",
  "identifier": "com.flowlink.app",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowLink",
        "width": 450,
        "height": 448,
        "minWidth": 450,
        "minHeight": 448,
        "maxWidth": 450,
        "maxHeight": 448,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": true,
        "shadow": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": ["tooltip"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
